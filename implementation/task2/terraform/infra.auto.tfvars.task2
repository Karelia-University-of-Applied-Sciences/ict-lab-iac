# infra.auto.tfvars file without UUIDs

# Infrastructure
cluster_uuid        = ""
default_subnet_uuid = ""
project_name        = "alex-iac-thesis-task2"

# VM Configuration
disk_size_gb = 20
image_uuid     = ""
vm_name_prefix = "alex-tf-task2-vm"
power_state    = "ON"

# Ubuntu password (shared across all VMs)
# ubuntu_password = "<PASSWORD>"
ubuntu_ssh_keys = [""]

# Optional: Shared admin users on all VMs (ansible, deploy, etc)
admin_users = [
  { name = "ansible", ssh_keys = [""] },
]

# Users: Each user gets one VM
users = [
  { name = "donald", ssh_keys = ["ssh-rsa "], sudo = true },
  { name = "mickey", password = "mouse", expiredate = "2026-04-10" },
]

# Optional: NGT ISO UUID for guest tools installation
# ngt_iso_uuid = "<NGT_ISO_UUID>"
