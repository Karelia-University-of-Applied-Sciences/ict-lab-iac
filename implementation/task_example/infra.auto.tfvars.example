# Infrastructure
cluster_uuid        = "<CLUSTER_UUID>"
default_subnet_uuid = "<SUBNET_UUID>"
project_name        = "<PROJECT_NAME>"

# VM Configuration
disk_size_gb   = 20
image_uuid     = "<IMAGE_UUID>"
vm_name_prefix = "<VM_NAME_PREFIX>"
power_state    = "ON"

# Ubuntu password (shared across all VMs)
# ubuntu_password = "<PASSWORD>"
ubuntu_ssh_keys = ["<SSH_PUBLIC_KEY>"]

# Optional: Shared admin users on all VMs (ansible, deploy, etc)
# admin_users = [
#   { name = "ansible", ssh_keys = ["<SSH_PUBLIC_KEY>"] },
#   { name = "deploy", password = "<PASSWORD>" },
# ]

# Users: Each user gets one VM
users = [
  { name = "<USER1>", password = "<PASSWORD>", sudo = true },
  { name = "<USER2>", password = "<PASSWORD>" },
]

# Optional: NGT ISO UUID for guest tools installation
# ngt_iso_uuid = "<NGT_ISO_UUID>"
