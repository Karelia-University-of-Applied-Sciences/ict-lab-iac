# Infrastructure
cluster_uuid        = "000622f6-5ec8-d3d7-3fc4-0025b500001f"
default_subnet_uuid = "af14bc37-f8b0-4729-b58e-3f078c29dbb7"
project_name        = "alex-iac-thesis-task1"

# VM Configuration
disk_size_gb = 20
#iso_uuid       = "cbe2cfb7-aefa-4b9d-a2c5-bc0a8b3d605b" # ubuntu-24.04.2-live-server
image_uuid     = "1d88e49d-b53a-4b05-888a-2f169652a975"
vm_name_prefix = "alex-tf-task1-vm"
power_state    = "ON"

# Ubuntu password (shared across all VMs)
# ubuntu_password = "<PASSWORD>"
ubuntu_ssh_keys = ["<SSH_PUBLIC_KEY>"]

# Optional: Shared admin users on all VMs (ansible, deploy, etc)
# admin_users = [
#   { name = "ansible", ssh_keys = ["<SSH_PUBLIC_KEY>"] },
#   { name = "deploy", password = "<PASSWORD>" },
# ]

# Users: Each user gets one VM
users = [
  { name = "neo", password = "<PASSWORD>", sudo = true },
  { name = "morpheus", password = "<PASSWORD>" },
  { name = "trinity", password = "<PASSWORD>", sudo = false },
]

# Optional: NGT ISO UUID for guest tools installation
# ngt_iso_uuid = "ngt-iso-uuid-here"
