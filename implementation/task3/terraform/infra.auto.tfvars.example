# Infrastructure
cluster_uuid        = "<CLUSTER_UUID>"
default_subnet_uuid = "<SUBNET_UUID>"
project_name        = "<PROJECT_NAME>"

# VM Configuration
disk_size_gb   = 20
image_uuid     = "<IMAGE_UUID>"
vm_name_prefix = "<VM_NAME_PREFIX>"
power_state    = "ON"

# SSH keys for ubuntu admin on all VMs
ubuntu_ssh_keys = ["<SSH_PUBLIC_KEY>"]

# Shared admin users on all VMs (ansible, deploy, etc)
admin_users = [
  { name = "ansible", ssh_keys = ["<SSH_PUBLIC_KEY>"] },
]

# Web server pool — add names to scale out the HTTPS round-robin pool
# Each name provisions one VM, gets a CA-signed cert, and is added to the LB upstream
web_server_names = ["web1", "web2"]

# Optional: NGT ISO UUID for guest tools installation
# ngt_iso_uuid = "<NGT_ISO_UUID>"
